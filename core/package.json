{
  "name": "zapret-control",
  "version": "1.0.0",
  "description": "Графический интерфейс управления Zapret HUB (обвязка над Flowseal zapret-discord-youtube)",
  "main": "main.js",
  "author": "_SAMOREZ_",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable",
    "pack": "node tools/pack-zip.js"
  },
  "build": {
    "appId": "com.zapret.control",
    "productName": "Zapret Control",
    "win": {
      "target": [
        "portable"
      ],
      "requestedExecutionLevel": "requireAdministrator",
      "icon": "assets/icon.ico"
    },
    "portable": {
      "artifactName": "ZapretControl-portable.exe"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
